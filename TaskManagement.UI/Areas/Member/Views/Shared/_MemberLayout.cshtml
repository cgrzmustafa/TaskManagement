<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="" />
    <meta name="author" content="" />
    <title>@ViewBag.Title</title>
    <!-- Favicon-->
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico" />
    <!-- Core theme CSS (includes Bootstrap)-->
    <link href="/theme/css/styles.css" rel="stylesheet" />
    <!-- Google Fonts (auth ekranlarıyla ortak) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f7f8fa;
            --panel-dark: #0e2340;
            --accent: #2f6fad;
            --accent-soft: #eaf1f8;
            --text-dark: #1a2536;
            --muted: #6b7789;
            --line: #e4e7ec;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: 'Inter',sans-serif;
            background: var(--bg);
            color: var(--text-dark);
            font-size: .94rem;
        }

        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-thumb {
            background: #d5d9e0;
            border-radius: 8px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        #wrapper {
            min-height: 100vh;
        }

        /* --- Sidebar --- */
        #sidebar-wrapper {
            width: 252px;
            min-height: 100vh;
            background: var(--panel-dark) !important;
            border-right: 1px solid rgba(255,255,255,.06) !important;
            transition: margin .22s ease;
            position: relative;
            z-index: 2;
        }

        #wrapper.toggled #sidebar-wrapper {
            margin-left: -252px;
        }

        .sidebar-heading {
            background: transparent !important;
            border-bottom: 1px solid rgba(255,255,255,.08) !important;
            color: rgba(255,255,255,.9);
            font-family: 'Inter',sans-serif;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
            font-size: .72rem;
            padding: 20px 24px !important;
        }

        #sidebar-wrapper .list-group {
            padding: 8px 10px;
        }

        #sidebar-wrapper .list-group-item {
            background: transparent !important;
            border: none !important;
            color: rgba(255,255,255,.62) !important;
            font-size: .87rem;
            font-weight: 500;
            padding: 10px 14px !important;
            border-radius: 6px;
            margin-bottom: 1px;
            border-left: 2px solid transparent !important;
            transition: background .15s ease, color .15s ease, border-color .15s ease;
        }

            #sidebar-wrapper .list-group-item:hover {
                background: rgba(255,255,255,.04) !important;
                color: #fff !important;
            }

            #sidebar-wrapper .list-group-item.active,
            #sidebar-wrapper .list-group-item:active {
                background: rgba(255,255,255,.05) !important;
                border-left-color: var(--accent) !important;
                color: #fff !important;
            }

        /* --- Content area --- */
        #page-content-wrapper {
            min-width: 0;
        }

        .navbar {
            background: #fff !important;
            border-bottom: 1px solid var(--line) !important;
            padding: 12px 8px;
            position: sticky;
            top: 0;
            z-index: 1;
        }

        #sidebarToggle {
            background: #fff !important;
            border: 1px solid var(--line) !important;
            color: var(--text-dark) !important;
            font-weight: 600;
            font-size: .82rem;
            padding: 7px 16px !important;
            border-radius: 6px;
            transition: background .15s ease, border-color .15s ease;
        }

            #sidebarToggle:hover {
                background: var(--accent-soft) !important;
                border-color: var(--accent) !important;
                color: var(--accent) !important;
            }

        .container-fluid {
            padding: 0;
        }

        #page-content-wrapper > .container-fluid {
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 10px;
            margin: 24px;
            padding: 28px;
            min-height: calc(100vh - 120px);
        }

        #page-content-wrapper h1,
        #page-content-wrapper h2,
        #page-content-wrapper h3 {
            font-family: 'Inter',sans-serif;
            font-weight: 700;
            color: var(--text-dark);
        }
    </style>
</head>
<body>
    <div class="d-flex" id="wrapper">
        <!-- Sidebar-->
        <div class="border-end bg-white" id="sidebar-wrapper">
            <div class="sidebar-heading border-bottom bg-light">Work Order App</div>
            <div class="list-group list-group-flush">
                <a class="list-group-item list-group-item-action list-group-item-light p-3 @(ViewBag.Active=="Profil"?"active":"")" asp-action="UserDetail" asp-controller="User" asp-area="Memmber">Profil</a>
                <a class="list-group-item list-group-item-action list-group-item-light p-3 @(ViewBag.Active=="AppTask"?"active":"")" asp-action="List" asp-controller="AppTask" asp-area="Member">İş Emirleri</a>
                <a class="list-group-item list-group-item-action list-group-item-light p-3 @(ViewBag.Active=="Notification"?"active":"")" asp-action="List" asp-controller="Notification" asp-area="Member">Bildirimler</a>
                <a class="list-group-item list-group-item-action list-group-item-light p-3" asp-action="LogOut" asp-controller="Account" asp-area="">Çıkış Yap</a>
            </div>
        </div>
        <!-- Page content wrapper-->
        <div id="page-content-wrapper">
            <!-- Top navigation-->
            <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
                <div class="container-fluid">
                    <button class="btn btn-primary" id="sidebarToggle">Menü</button>
                </div>
            </nav>
            <!-- Page content-->
            <div class="container-fluid">
                @RenderBody()
            </div>
        </div>
    </div>
    <!-- Bootstrap core JS-->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Core theme JS-->
    <script src="/theme/js/scripts.js"></script>
</body>
</html>