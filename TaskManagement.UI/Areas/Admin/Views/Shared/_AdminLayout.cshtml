<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="" />
    <meta name="author" content="" />
    <title>@ViewBag.Title</title>
    <!-- Favicon-->
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico" />
    <!-- Core theme CSS (includes Bootstrap)-->
    <link href="/theme/css/styles.css" rel="stylesheet" />
    <!-- Google Fonts (auth ekranlarıyla ortak) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #eef1f6;
            --panel-dark: #0e2a4d;
            --accent: #2f6fad;
            --accent-soft: #eaf1f8;
            --text-dark: #15243a;
            --muted: #6b7789;
            --line: #e1e6ee;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: 'Inter',sans-serif;
            background: var(--bg);
            color: var(--text-dark);
        }

        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-thumb {
            background: #c7d0dc;
            border-radius: 8px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        #wrapper {
            min-height: 100vh;
        }

        /* --- Sidebar --- */
        #sidebar-wrapper {
            width: 264px;
            min-height: 100vh;
            background: linear-gradient(180deg,#0e2a4d 0%, #0a1f3a 100%) !important;
            border-color: transparent !important;
            box-shadow: 2px 0 18px rgba(14,42,77,.12);
            transition: margin .3s cubic-bezier(.4,0,.2,1);
            position: relative;
            z-index: 2;
        }

        #wrapper.toggled #sidebar-wrapper {
            margin-left: -264px;
        }

        .sidebar-heading {
            background: transparent !important;
            border-bottom: 1px solid rgba(255,255,255,.08) !important;
            color: #fff;
            font-family: 'Fraunces',serif;
            font-weight: 600;
            letter-spacing: .02em;
            font-size: 1.05rem;
            padding: 26px 26px !important;
            position: relative;
        }

            .sidebar-heading::after {
                content: "";
                position: absolute;
                left: 26px;
                bottom: -1px;
                width: 32px;
                height: 2px;
                background: var(--accent);
                border-radius: 2px;
            }

        #sidebar-wrapper .list-group {
            padding: 14px 12px;
        }

        #sidebar-wrapper .list-group-item {
            background: transparent !important;
            border: none !important;
            color: rgba(255,255,255,.68) !important;
            font-size: .9rem;
            font-weight: 500;
            padding: 12px 16px !important;
            border-radius: 9px;
            margin-bottom: 3px;
            position: relative;
            transition: background .18s ease, color .18s ease, padding-left .18s ease;
        }

            #sidebar-wrapper .list-group-item::before {
                content: "";
                position: absolute;
                left: 0;
                top: 50%;
                width: 3px;
                height: 0;
                background: var(--accent);
                border-radius: 0 3px 3px 0;
                transform: translateY(-50%);
                transition: height .18s ease;
            }

            #sidebar-wrapper .list-group-item:hover {
                background: rgba(255,255,255,.06) !important;
                color: #fff !important;
                padding-left: 20px !important;
            }

            #sidebar-wrapper .list-group-item.active,
            #sidebar-wrapper .list-group-item:active {
                background: rgba(47,111,173,.22) !important;
                color: #fff !important;
            }

                #sidebar-wrapper .list-group-item.active::before,
                #sidebar-wrapper .list-group-item:active::before {
                    height: 60%;
                }

        /* --- Content area --- */
        #page-content-wrapper {
            min-width: 0;
        }

        .navbar {
            background: rgba(255,255,255,.85) !important;
            backdrop-filter: blur(10px);
            border-color: var(--line) !important;
            box-shadow: 0 1px 12px rgba(15,36,58,.05);
            padding: 14px 8px;
            position: sticky;
            top: 0;
            z-index: 1;
        }

        #sidebarToggle {
            background: var(--panel-dark) !important;
            border: none !important;
            color: #fff !important;
            font-weight: 600;
            font-size: .85rem;
            letter-spacing: .02em;
            padding: 9px 20px !important;
            border-radius: 8px;
            box-shadow: 0 3px 10px rgba(14,42,77,.25);
            transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
        }

            #sidebarToggle:hover {
                transform: translateY(-1px);
                box-shadow: 0 5px 14px rgba(14,42,77,.32);
                background: var(--accent) !important;
                color: #fff !important;
            }

            #sidebarToggle:active {
                transform: translateY(0);
            }

        .container-fluid {
            padding: 30px 28px;
        }

        #page-content-wrapper > .container-fluid {
            background: #fff;
            border-radius: 16px;
            margin: 22px;
            padding: 32px;
            box-shadow: 0 2px 20px rgba(15,36,58,.06);
            min-height: calc(100vh - 130px);
        }
    </style>
</head>
<body>
    <div class="d-flex" id="wrapper">
        <!-- Sidebar-->
        <div class="border-end bg-white" id="sidebar-wrapper">
            <div class="sidebar-heading border-bottom bg-light">Work Order App</div>
            <div class="list-group list-group-flush">
                <a class="list-group-item list-group-item-action list-group-item-light p-3" href="#!">Gösterge Paneli</a>
                <a class="list-group-item list-group-item-action list-group-item-light p-3 @(ViewBag.Active=="Priority"?"active":"")" asp-action="List" asp-controller="Priority">Aciliyet Durumları</a>
                <a class="list-group-item list-group-item-action list-group-item-light p-3 @(ViewBag.Active=="AppTask"?"active":"")" asp-action="List" asp-controller="AppTask" asp-area="Admin">İş Emirleri</a>
                <a class="list-group-item list-group-item-action list-group-item-light p-3 @(ViewBag.Active=="Members"?"active":"")" asp-action="List" asp-controller="User" asp-area="Admin" >Kullanıcılar</a>
                <a class="list-group-item list-group-item-action list-group-item-light p-3" href="#!">Profile</a>
                <a class="list-group-item list-group-item-action list-group-item-light p-3" href="#!">Status</a>
            </div>
        </div>
        <!-- Page content wrapper-->
        <div id="page-content-wrapper">
            <!-- Top navigation-->
            <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
                <div class="container-fluid">
                    <button class="btn btn-primary" id="sidebarToggle">Menü</button>
                </div>
            </nav>
            <!-- Page content-->
            <div class="container-fluid">
                @RenderBody()
            </div>
        </div>
    </div>
    <!-- Bootstrap core JS-->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Core theme JS-->
    <script src="/theme/js/scripts.js"></script>
</body>
</html>