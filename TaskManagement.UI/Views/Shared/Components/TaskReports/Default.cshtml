@model List<TaskReportListDto>
<style>
    .task-report-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0 0 14px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--line);
    }

    .task-report-wrap {
        border: 1px solid var(--line);
        border-radius: 10px;
        overflow: hidden;
    }

        .task-report-wrap .table {
            margin-bottom: 0;
        }

            .task-report-wrap .table thead th {
                background: #f7f8fa;
                color: var(--muted);
                text-transform: uppercase;
                letter-spacing: .04em;
                font-size: .72rem;
                font-weight: 700;
                border-bottom: 1px solid var(--line);
                padding: 12px 16px;
            }

            .task-report-wrap .table tbody td {
                padding: 12px 16px;
                font-size: .88rem; 
                color: var(--text-dark);
                border-top: 1px solid var(--line);
                vertical-align: middle;
            }

            .task-report-wrap .table tbody tr:hover {
                background: var(--accent-soft);
            }
</style>

<h5 class="task-report-title">Kaydedilen Aşamalar</h5>
<div class="task-report-wrap">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Tanım</th>
                <th>Açıklama</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var taskReport in Model)
            {
                <tr>
                    <td>@taskReport.Definition</td>
                    <td>@taskReport.Detail</td>
                </tr>
            }
        </tbody>
    </table>
</div>